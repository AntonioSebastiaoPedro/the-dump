Class GrenadeLauncher40mm : Weapon 
{
Default
{
	Inventory.PickupMessage "You got the 40mm Grenade Launcher!.";
	Weapon.Ammogive 10;
	Weapon.AmmoType1 "Grenades40mm";
	Weapon.AmmoType2 "Grenades40mm";
	Weapon.AmmoUse1 1;
	Weapon.AmmoUse2 1;
	Weapon.SelectionOrder 400;
	Weapon.SlotNumber 5;
	+WEAPON.EXPLOSIVE
	Obituary "%o was blown up by %k's Grenade Launcher.";
	}
	States
	{
	Ready:
		RGLG A 1 A_WeaponReady;
		Loop;
	Select:
		RGLG A 1 A_Raise;
		Loop;
	Deselect:
		RGLG A 1 A_Lower;
		Loop;
	Fire:
		RGLF A 2 Bright;
		RGLF A 0 A_GunFlash ;
		RGLF A 0 A_PlayWeaponSound ("40mm/grenfire");
		RGLF B 2 Bright A_FireProjectile("Shot40mm", 0, 1, 0, 10, FPF_NOAUTOAIM , 1);
		RGLF C 2Bright;
		RGLF B 0 ;
		RGLG ABCD 3;
		RGLG A 12 ;
		RGLG A 5 A_ReFire;
		Goto Ready;
	AltFire:
		RGLF A 2 Bright;
		RGLF A 0 A_GunFlash ;
		RGLF A 0 A_PlayWeaponSound ("40mm/grenfire");
		RGLF B 2 Bright A_FireProjectile("TimedShot40mm", 0, 1, 0, 10, FPF_NOAUTOAIM , 1) ;
		RGLF C 2 Bright;
		RGLF B 0 ;
		RGLG ABCD 3;
		RGLG A 12 ;
		RGLG A 5 A_ReFire;
		Goto Ready;
	Flash:
		TNT1 A 1 BRIGHT A_Light1;
		TNT1 B 2 BRIGHT A_Light2;
		Goto LightDone;
	Spawn:
		GLMM A -1;
		Stop;
	}
}

Class Shot40mm : Actor
{
Default
{
	Radius 8;
	Height 8;
	Damage 25;
	Speed 50;
	Scale 0.75;
	SeeSound "40mm/grenbounce";
	DeathSound "40mm/grenexplode";
	Projectile;
	ReactionTime 15;
	Decal "Scorch";
	-NOGRAVITY
	}
	States
	{
	Spawn:
		SHRP O 3 bright A_SpawnItemEX("GrenadeSmoke",0,0,0,0,0,0,0,2);
		SHRP O 0 A_CountDown;
		Loop;
	Death:
		MIS6 B 0 A_NoGravity;
		MIS6 B 0 A_Explode;
		MIS6 B 3 bright A_SetTranslucent (0.85,1);
		MIS6 C 3 bright;
		MIS6 DEF 3 bright ;
		Stop;
	}
}

